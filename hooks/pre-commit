#!/usr/bin/env bash
# pre-commit hook — validate a foreign nixos config builds against this repo
#
# Workflow:
# 1. Clone the target nixos config repo into a temp directory
# 2. Optionally unlock git-crypt encrypted files if public-keys.txt is present
# 3. Run nixos-rebuild build against the cloned config, overriding the flake
#    input that points to this repo with the local checkout path so the build
#    uses the current source (plus any extra overrides from EXTRA_NIX_OVERRIDES)
#
# Template placeholders (@REPO_URL@, @FLAKE_INPUT@, @BRANCH@) are substituted
# by install-hooks.py at install time.
set -e

REPO_URL="@REPO_URL@"
FLAKE_INPUT="@FLAKE_INPUT@"
BRANCH="@BRANCH@"

THIS_REPO="$(git rev-parse --show-toplevel)"

# ---- sync check: fetch latest remote refs before validating ----
#
# Use `git fetch` (NOT pull/merge) to sync remote refs without triggering
# hooks — this avoids a validation loop when the hook runs during
# pull/merge/rebase.
echo "[pre-commit] fetching upstream"
git fetch --quiet

# Compare local HEAD against the upstream tracking branch:
#   - HEAD behind upstream  → refuse: user must pull remote changes first
#   - HEAD == upstream      → proceed (staged changes need validation)
#   - HEAD ahead of upstream → proceed (unpushed local work needs validation)
if git rev-parse '@{u}' >/dev/null 2>&1; then
    if [ "$(git rev-parse HEAD)" != "$(git rev-parse '@{u}')" ] && \
       git merge-base --is-ancestor HEAD '@{u}'; then
        echo "[pre-commit] local HEAD is behind upstream — pull remote changes before committing"
        exit 1
    fi
fi

# ---------------------------------------------------------

# stash any unstaged changes to prevent impact
git stash --keep-index --include-untracked

# Build up --override-input arguments.
# Primary override: replace the flake input that normally points to this
# repo with the actual local checkout so the build uses the current source.
OVERRIDE_ARGS=(--override-input "$FLAKE_INPUT" "$THIS_REPO")

# EXTRA_NIX_OVERRIDES allows additional flake input replacements at runtime.
# Format: semicolon-separated "input=path" pairs.
# Example: EXTRA_NIX_OVERRIDES="nixpkgs=/path/to/nixpkgs;utils=/path/to/utils"
if [ -n "${EXTRA_NIX_OVERRIDES:-}" ]; then
    IFS=';' read -ra pairs <<< "$EXTRA_NIX_OVERRIDES"
    for pair in "${pairs[@]}"; do
        # Split on the FIRST '=' only — flake references/paths may contain
        # '=' in query parameters (e.g. ?rev=abc123, ?dir=subdir).
        if [[ "$pair" =~ ^([^=]+)=(.*)$ ]]; then
            input="${BASH_REMATCH[1]}"
            path="${BASH_REMATCH[2]}"
            if [ -n "$input" ] && [ -n "$path" ]; then
                echo "[pre-commit] extra override: '$input' → $path"
                OVERRIDE_ARGS+=(--override-input "$input" "$path")
            fi
        fi
    done
fi

cd "$THIS_REPO" && nix flake update "${OVERRIDE_ARGS[@]}"

WORK_DIR="$(mktemp -d)"
trap 'rm -rf "$WORK_DIR"' EXIT

echo "[pre-commit] cloning $REPO_URL${BRANCH:+ (branch: $BRANCH)}"

if [ -n "$BRANCH" ]; then
    git clone --branch "$BRANCH" "$REPO_URL" "$WORK_DIR/cloned"
else
    git clone "$REPO_URL" "$WORK_DIR/cloned"
fi

cd "$WORK_DIR/cloned"

if [ -f public-keys.txt ]; then
    echo "[pre-commit] importing GPG keys and unlocking git-crypt"
    gpg --import public-keys.txt
    git crypt unlock
else
    echo "[pre-commit] no public-keys.txt found, skipping git-crypt unlock"
fi

echo "[pre-commit] running nixos-rebuild build"
echo "[pre-commit] overriding flake input '$FLAKE_INPUT' → $THIS_REPO"

# Try the current hostname as a nixosConfiguration name first; if the cloned
# config doesn't define one, pick the first available configuration.
HOSTNAME="$(hostname)"

nix flake update "${OVERRIDE_ARGS[@]}"
nixos-rebuild build --flake "$WORK_DIR/cloned#$HOSTNAME" "${OVERRIDE_ARGS[@]}"

cd "$THIS_REPO" && git add flake.lock

echo "[pre-commit] build passed"

echo -e "\033[31mWARNING: remember to run git stash pop/apply to apply changes back(if any)!\033[0m"
